{
  "expo": {
    "name": "Maafushivaru Inventory",
    "slug": "mvm-inventory-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mvminventory",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0f172a",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Maafushivaru Inventory to use the camera to scan fuel chits, boat notes and expiry dates."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maafushivaru.inventory",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Maafushivaru Inventory to use the camera to scan fuel chits, boat notes and expiry dates."
      }
    },
    "android": {
      "package": "com.maafushivaru.inventory",
      "versionCode": 1,
      "permissions": ["INTERNET", "CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "SUPABASE_URL": "",
      "SUPABASE_ANON_KEY": "",
      "eas": {
        "projectId": ""
      }
    }
  }
}
